# Server
PORT=3000

# App URL (used in email links — no trailing slash)
APP_URL=http://localhost:3000

# Building name shown in emails and the UI
BUILDING_NAME=Sunset Apartments

# ── Email (choose one) ──────────────────────────────────────────────────────

# Option 1: Gmail (easiest — no sign-up needed)
# 1. Go to myaccount.google.com/apppasswords
# 2. Create an app password called "Rooftop Scheduler"
# 3. Paste the 16-character password below (spaces are fine)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Option 2: SendGrid
# SENDGRID_API_KEY=SG.your_key_here
# FROM_EMAIL=noreply@yourdomain.com
# FROM_NAME=Rooftop Scheduler
